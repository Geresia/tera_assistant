{
  "manifest_version": 3,
  "name": "Trip.com Room Scraper",
  "version": "5.0",
  "description": "Automatically scrape hotel room data from Trip.com and send to Google Sheets",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "sidePanel",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.trip.com/*",
    "https://*.trip.com/*",
    "https://script.google.com/*",
    "https://*.tripcdn.com/*",
    "https://*.c-ctrip.com/*",
    "https://raw.githubusercontent.com/*",
    "https://tera.traveloka.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["jszip.min.js"],
      "matches": ["https://www.trip.com/*"]
    }
  ]
}